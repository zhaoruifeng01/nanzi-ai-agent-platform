API_SERVICE_ENV=dev
API_SERVICE_PORT=8001
API_SERVICE_LOG_LEVEL=INFO
# 钉钉/企微报表简报中的完整报表链接域名
APP_PUBLIC_URL=https://yunshu.example.com

# MySQL
MYSQL_HOST=192.168.28.170
MYSQL_PORT=3306
MYSQL_DB=yunshu_ai_agent_platform
